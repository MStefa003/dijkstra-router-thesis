# ========================================
# API KEYS CONFIGURATION
# ========================================
# IMPORTANT: Never commit the actual .env file to GitHub!
# This is just a template. Copy this to .env and add your real API keys.

# ========================================
# REQUIRED API KEYS
# ========================================

# OpenRouteService API (REQUIRED for basic routing)
# Sign up at: https://openrouteservice.org/
ORS_API_KEY=your_ors_api_key_here

# TomTom Traffic API (REQUIRED for live traffic data)
# Sign up at: https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key_here

# ========================================
# OPTIONAL API KEYS (for additional features)
# ========================================

# HERE Traffic API (Optional - Free tier available)
# Sign up at: https://developer.here.com/
HERE_API_KEY=your_here_api_key_here

# MapBox Traffic API (Optional - Good free tier)
# Sign up at: https://www.mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Google Maps Traffic API (Paid, most accurate)
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_api_key_here

# OpenWeather API (for weather-based traffic adjustments)
# Sign up at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ========================================
# SETUP INSTRUCTIONS:
# ========================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Sign up for the APIs you want to use
# 3. Replace the placeholder values with your actual API keys
# 4. The .env file will be automatically ignored by Git
