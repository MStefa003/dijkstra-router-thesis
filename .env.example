# Copy this file to .env and fill in your API keys.
# The app works without any keys — traffic will fall back to simulated data.

# TomTom Traffic API — enables live traffic overlay
# https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key_here

# HERE Traffic API — optional, additional traffic source
# https://developer.here.com/
HERE_API_KEY=your_here_api_key_here

# MapBox — optional, additional traffic source
# https://www.mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Google Maps Traffic API — optional, most accurate but paid
# https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_api_key_here

# Flask secret key — change this for any non-local deployment
SECRET_KEY=change-me-in-production
